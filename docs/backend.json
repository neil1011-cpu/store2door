{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account within the SwiftRoute system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity (same as Firebase Auth UID)."
        },
        "fullName": {
          "type": "string",
          "description": "Full name of the user."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the user."
        },
        "trn": {
          "type": "string",
          "description": "Taxpayer Registration Number of the user."
        },
        "mailboxNumber": {
          "type": "string",
          "description": "The user's unique mailbox number."
        },
        "address": {
          "type": "object",
          "properties": {
            "address1": { "type": "string" },
            "address2": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zip": { "type": "string" }
          },
          "required": ["address1", "address2", "city", "state", "zip"]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was created.",
          "format": "date-time"
        },
        "dropoffAddresses": {
            "type": "array",
            "description": "A list of saved drop-off addresses in Jamaica for the user.",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "address": { "type": "string" },
                    "parish": { "type": "string" }
                },
                "required": ["id", "name", "address", "parish"]
            }
        },
        "pickupPersonnel": {
            "type": "array",
            "description": "A list of people authorized to pick up packages for the user.",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "idNumber": { "type": "string" }
                },
                "required": ["id", "name", "idNumber"]
            }
        }
      },
      "required": [
        "id",
        "fullName",
        "email",
        "phone",
        "trn",
        "mailboxNumber",
        "address",
        "createdAt"
      ]
    },
    "Shipment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Shipment",
      "type": "object",
      "description": "Represents a shipment being handled by SwiftRoute.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Shipment entity."
        },
        "trackingNumber": {
          "type": "string",
          "description": "The tracking number associated with the shipment."
        },
        "contents": {
          "type": "string",
          "description": "Description of the package contents."
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Processed", "In Transit", "Customs", "Delivered"],
          "description": "The current status of the shipment."
        },
        "date": {
            "type": "string",
            "format": "date-time"
        },
        "cost": { "type": "number" },
        "paymentStatus": {
          "type": "string",
          "enum": ["Paid", "Unpaid"]
        },
        "invoiceId": {
          "type": "string",
          "description": "ID of the associated invoice."
        },
        "invoiceUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the invoice PDF."
        },
        "customerId": {
          "type": "string",
          "description": "The UID of the user who owns this shipment."
        }
      },
      "required": [
        "trackingNumber",
        "contents",
        "status",
        "date",
        "customerId"
      ]
    },
    "PreAlert": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PreAlert",
      "type": "object",
      "description": "Represents a pre-alert request for a shipment from a customer.",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerId": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "contents": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Processed"] },
        "date": { "type": "string", "format": "date-time" },
        "invoiceUrl": { "type": "string", "format": "uri" }
      },
      "required": [
        "customerName",
        "customerId",
        "trackingNumber",
        "contents",
        "status",
        "date",
        "invoiceUrl"
      ]
    },
    "Message": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Message",
        "type": "object",
        "description": "A message within a support conversation.",
        "properties": {
            "id": { "type": "string" },
            "conversationId": { "type": "string" },
            "customerName": { "type": "string" },
            "customerId": { "type": "string" },
            "subject": { "type": "string" },
            "message": { "type": "string" },
            "date": { "type": "string", "format": "date-time" },
            "sender": { "type": "string", "enum": ["user", "agent"] },
            "status": { "type": "string", "enum": ["Open", "Closed"] },
            "attachment": { "type": "string", "format": "uri" }
        },
        "required": ["conversationId", "customerId", "customerName", "subject", "message", "date", "sender", "status"]
    },
    "Invoice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Invoice",
      "type": "object",
      "description": "Represents a customer invoice.",
      "properties": {
        "invoiceId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Paid", "Unpaid"] },
        "invoiceUrl": { "type": "string", "format": "uri" }
      },
      "required": ["invoiceId", "customerId", "customerName", "date", "amount", "status", "invoiceUrl"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/entities/User" },
          "description": "Stores public-facing user profile information."
        }
      },
      {
        "path": "/shipments/{shipmentId}",
        "definition": {
          "entityName": "Shipment",
          "schema": { "$ref": "#/entities/Shipment" },
          "description": "Collection of all shipments. Access is controlled via security rules based on customerId field."
        }
      },
      {
        "path": "/preAlerts/{preAlertId}",
        "definition": {
          "entityName": "PreAlert",
          "schema": { "$ref": "#/entities/PreAlert" },
          "description": "Collection of all pre-alerts submitted by customers."
        }
      },
      {
        "path": "/conversations/{conversationId}/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/entities/Message" },
          "description": "Stores all messages for all support conversations."
        }
      },
      {
        "path": "/invoices/{invoiceId}",
        "definition": {
            "entityName": "Invoice",
            "schema": { "$ref": "#/entities/Invoice"},
            "description": "Collection of all generated invoices."
        }
      }
    ]
  }
}
