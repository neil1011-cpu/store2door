
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores additional profile information for users authenticated via an external system, such as contact details and user roles.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity, corresponding to the external authentication system's user ID."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the user."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's contact phone number."
        },
        "address": {
          "type": "object",
          "properties": {
            "address1": { "type": "string" },
            "address2": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zip": { "type": "string" }
          }
        },
        "role": {
          "type": "string",
          "description": "The role of the user within the system (e.g., 'customer', 'admin', 'staff')."
        },
        "mailboxNumber": { "type": "string" },
        "trn": { "type": "string" },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user profile was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "firstName",
        "lastName",
        "mailboxNumber",
        "createdAt"
      ]
    },
    "PreAlert": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PreAlert",
      "type": "object",
      "description": "Represents a pre-alert request submitted by a user.",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "contents": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Processed"] },
        "submissionDate": { "type": "string", "format": "date-time" },
        "uploadedInvoiceUrl": { "type": "string" }
      }
    },
    "Shipment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Shipment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "contents": { "type": "string" },
        "status": { "type": "string" },
        "shippingDate": { "type": "string", "format": "date-time" },
        "cost": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Unpaid"] }
      }
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Records every movement of funds (revenue or expense) for financial auditing.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["revenue", "expense"] },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "method": { "type": "string" },
        "customerId": { "type": "string" },
        "source": { "type": "string", "description": "e.g., 'POS', 'Online', 'Manual'" },
        "invoiceIds": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "Primary user profile storage."
        }
      },
      {
        "path": "/users/{userId}/pre_alerts/{preAlertId}",
        "definition": {
          "entityName": "PreAlert",
          "description": "User-specific pre-alert records."
        }
      },
      {
        "path": "/users/{userId}/shipments/{shipmentId}",
        "definition": {
          "entityName": "Shipment",
          "description": "User-specific shipment records."
        }
      },
      {
        "path": "/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "description": "Global financial ledger."
        }
      },
      {
        "path": "/admin_roles/{adminUid}",
        "definition": {
          "description": "Grants administrative access if document exists."
        }
      }
    ]
  }
}
