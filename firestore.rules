
/**
 * This ruleset enforces a hybrid security model for the SwiftRoute application.
 * It combines strict user-ownership for personal data with a role-based
 * access control (RBAC) system for administrative functions.
 *
 * Core Philosophy:
 * - User data is private by default and accessible only to the owning user.
 * - A separate, client-read-only collection (`/roles_admin`) defines administrators.
 * - Administrators have read and write access to all data for management purposes.
 * - The default security posture is to deny access unless explicitly granted.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for reusable logic
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isAdmin() {
      // Check for existence of the user's UID in the roles_admin collection.
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    function isNewUser(userId) {
      // A user is new if they are authenticated and don't have a profile document yet.
      return isOwner(userId) && !exists(/databases/$(database)/documents/users/$(userId));
    }
    function isUpdatingOwnProfile(userId) {
       // A user can update their own profile.
       return isOwner(userId) && resource.data.id == userId;
    }
    function noAdminsExist() {
      // Check if the roles_admin collection is empty by checking its size.
      return get(/databases/$(database)/documents/roles_admin).size == 0;
    }
     function isCreatingFirstAdmin(userId) {
      // Allow creation only if it's the requesting user and the roles_admin collection is currently empty.
      return isOwner(userId) && noAdminsExist();
    }


    /**
     * @description Manages user profile data.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      // Allow a user to create their own profile. Allow the first admin to create their own profile during setup.
      allow create: if (isNewUser(userId) && request.resource.data.id == userId) || isCreatingFirstAdmin(userId);
      allow update: if isUpdatingOwnProfile(userId) || isAdmin();
      allow delete: if isAdmin(); // Only admins can delete user profiles
    }

    /**
     * @description Manages user-specific subcollections.
     * Path-based ownership ensures users can only access their own data.
     */
    match /users/{userId}/{subcollection}/{docId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) || isAdmin()) && request.resource.data.customerId == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.customerId == resource.data.customerId;
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    /**
     * @description Collection group queries for admins.
     * Allows admins to query across all users' subcollections.
     */
     match /{path=**}/shipments/{shipmentId} {
       allow get, list: if isAdmin();
     }
     match /{path=**}/pre_alerts/{preAlertId} {
       allow get, list: if isAdmin();
     }
      match /{path=**}/conversations/{convoId} {
       allow get, list: if isAdmin();
     }

    /**
     * @description Manages global data collections restricted to administrators.
     */
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
    }
    
    match /flight_manifests/{flightManifestId} {
      allow read, write: if isAdmin();
    }

    match /profit_loss_statements/{profitLossStatementId} {
      allow read, write: if isAdmin();
    }
    
    match /rates/{rateId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Defines which users have administrative privileges.
     * This collection should only be managed by a trusted backend environment,
     * except for the very first admin creation.
     */
    match /roles_admin/{userId} {
      // Allow any authenticated user to check their own admin status document.
      allow get: if isOwner(userId);
      // Allow the client to check if any admins exist on the setup page.
      allow list: if noAdminsExist();
      // Allow a write operation only if it's the user creating their own admin doc AND no other admins exist.
      allow create: if isCreatingFirstAdmin(userId);
      // Do not allow client-side updates or deletes to admin roles for security.
      allow update, delete: if false;
    }
  }
}
