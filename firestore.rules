
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Admin = has a doc in roles_admin/{uid}
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- ADMIN ROLES ---
    match /roles_admin/{userId} {
      // Allow the admin himself to read his role doc
      allow get: if request.auth != null && isOwner(userId);

      // TEMP: allow creation from client while you bootstrap.
      // Once you're done, lock this back down.
      allow create: if request.auth != null && isOwner(userId);

      allow update, delete: if false;
    }

    // --- USERS ROOT COLLECTION ---
    match /users/{userId} {
      // A user can see their own profile; admins can see everyone
      allow get: if isOwner(userId) || isAdmin();

      // IMPORTANT: allows your admin to query `collection('users')`
      allow list: if isAdmin();

      // Basic create/update/delete rules (adjust as you like)
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- USER SUBCOLLECTIONS (INCLUDING /users/{uid}/shipments/{id}) ---
    match /users/{userId}/{subcollection}/{docId} {
      // Admin can read all; user can read own
      allow get, list: if isOwner(userId) || isAdmin();

      // Admin or owner can write
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    // --- GLOBAL COLLECTIONS (ADMIN-ONLY) ---
    match /invoices/{invoiceId} {
        allow get, list, create, update, delete: if isAdmin();
    }

    // --- COLLECTION GROUP QUERIES (ADMIN-ONLY) ---
    match /{path=**}/shipments/{shipmentId} {
      allow read: if isAdmin();
    }
    match /{path=**}/pre_alerts/{preAlertId} {
      allow read: if isAdmin();
    }
    match /{path=**}/conversations/{convoId} {
      allow read: if isAdmin();
    }
  }
}
