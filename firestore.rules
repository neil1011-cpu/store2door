
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------
    // HELPERS
    // ----------------------------------------------------------
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // ----------------------------------------------------------
    // METADATA COLLECTION (FOR COUNTERS, ETC.)
    // ----------------------------------------------------------
    match /metadata/mailboxCounter {
      // Any authenticated user can read and update the counter.
      // This is safe because updates are handled within a transaction
      // in the sign-up logic, preventing race conditions.
      allow read, update: if request.auth != null;
      allow create, delete: if false; // Should only be created on setup
    }


    // ----------------------------------------------------------
    // ADMIN ROLES COLLECTION
    // ----------------------------------------------------------
    match /roles_admin/{userId} {

      // Admin can read their own role doc
      allow get: if request.auth != null && isOwner(userId);
      
      // ONLY the setup-admin page (or a server process) should create an admin.
      // This rule is changed to prevent any client from creating an admin role.
      allow create: if false;

      // No client-side modifications to admin roles
      allow update, delete: if false;
    }

    // ----------------------------------------------------------
    // USERS ROOT COLLECTION
    // ----------------------------------------------------------
    match /users/{userId} {

      // User or admin can read their profile
      allow get: if isOwner(userId) || isAdmin();

      // Combined list rule: Admins can list all users. 
      // Any authenticated user can perform a count.
      allow list: if isAdmin() || (request.auth != null && query.limit == 0);

      // User can create their own profile OR admin can create it for them
      allow create: if isOwner(userId) || isAdmin();

      // User or admin can update
      allow update: if isOwner(userId) || isAdmin();

      // Only admin can delete
      allow delete: if isAdmin();
    }


    // ----------------------------------------------------------
    // USERS SUBCOLLECTIONS (ADDRESSES, SHIPMENTS, PRE_ALERTS, ETC.)
    // ----------------------------------------------------------
    match /users/{userId}/{subcollection}/{docId} {

      // Admin can see any document; user can see their own
      allow get, list: if isOwner(userId) || isAdmin();

      // Admin or owner can write
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    // ----------------------------------------------------------
    // GLOBAL ADMIN-ONLY COLLECTIONS
    // ----------------------------------------------------------
    match /invoices/{invoiceId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /rates/{rateId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /flight_manifests/{manifestId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /profit_loss_statements/{plsId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    // ----------------------------------------------------------
    // COLLECTION GROUP QUERIES (VERY IMPORTANT)
    // REQUIRED for collectionGroup('shipments'), etc.
    // ----------------------------------------------------------

    // SHIPMENTS
    match /{path=**}/shipments/{shipmentId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow update, delete, create: if isAdmin();
    }

    // PRE ALERTS
    match /{path=**}/pre_alerts/{preAlertId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow update, delete, create: if isAdmin();
    }

    // CONVERSATIONS
    match /{path=**}/conversations/{convoId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow update, delete, create: if isAdmin();
    }
  }
}
