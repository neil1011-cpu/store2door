rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Administrators have full access.
    // We include a hardcoded email fallback to ensure the primary admin can always regain control.
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email == "admin@neilussolutions.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Global Admin Bypass ---
    // Administrators have full access to all paths, including collection groups.
    match /{allPaths=**} {
      allow read, write, list: if isAdmin();
    }

    // --- Collection Rules ---

    // Public read access to shipments by tracking number (for tracking page)
    match /{path=**}/shipments/{id} {
      allow read: if true;
      allow list: if isAdmin();
    }

    // Users and their subcollections
    match /users/{userId} {
       allow read: if isOwner(userId) || isAdmin();
       allow write: if isOwner(userId) || isAdmin();
       
       match /{allSubcollections=**} {
         allow read, write, list: if isOwner(userId) || isAdmin();
       }
    }

    // Allow authenticated users to read and initialize their own admin role status
    match /admin_roles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    // Explicit matches for Collection Groups (fixing root 'list' errors)
    match /{path=**}/pre_alerts/{id} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.customerId == request.auth.uid));
      allow list: if isAdmin();
    }
    
    match /{path=**}/pre_alerts {
       allow list: if isAdmin();
    }
    
    match /{path=**}/shipments {
       allow list: if isAdmin();
    }

    // Financials
    match /transactions/{id} {
       allow read, list, write: if isAdmin();
    }
    
    match /invoices/{id} {
       allow read, list, write: if isAdmin();
    }

    // Metadata access for mailbox sequence
    match /metadata/{id} {
      allow read, write: if isSignedIn();
    }
    
    // Sent emails history
    match /sent_emails/{id} {
       allow read, list: if isAdmin();
    }
  }
}
