/**
 * @fileOverview Firestore Security Rules for SwiftRoute.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and related data
 * (shipments, pre-alerts, support conversations, and invoices).  Users can only
 * access their own profile data and related data, unless explicitly specified otherwise.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, with the userId matching the Firebase Auth UID.
 * - /shipments/{shipmentId}: Stores shipment information.  Each shipment has a customerId field
 *   linking it to a user.
 * - /preAlerts/{preAlertId}: Stores pre-alert requests. Each pre-alert has a customerId field
 *   linking it to a user.
 * - /conversations/{conversationId}/messages/{messageId}: Stores support conversation messages, linked to a user.
 * - /invoices/{invoiceId}: Stores invoice data, linked to a user via customerId.
 *
 * Key Security Decisions:
 * - Users can only read/write their own user document.
 * - Shipments, pre-alerts, messages, and invoices are accessible only by their owner (customerId).
 * - Listing of user documents is disallowed.
 *
 * Denormalization for Authorization:
 * - The `shipments`, `preAlerts`, `messages`, and `invoices` collections all denormalize the `customerId`
 *   onto each document. This is CRITICAL for security; it allows rules to quickly and efficiently
 *   verify ownership without needing to perform expensive `get()` operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Defines helper function isSingedIn.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Defines helper function isOwner.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Defines helper function isExistingOwner.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Secure user profile documents.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' can create their own profile document with matching ID.
     * @allow (get) User with UID 'user123' can read their own profile document.
     * @allow (update) User with UID 'user123' can update their own profile document.
     * @allow (delete) User with UID 'user123' can delete their own profile document.
     * @deny (create) User with UID 'user456' cannot create a profile document for 'user123'.
     * @deny (get) User with UID 'user456' cannot read the profile document of 'user123'.
     * @deny (update) User with UID 'user456' cannot update the profile document of 'user123'.
     * @deny (delete) User with UID 'user456' cannot delete the profile document of 'user123'.
     * @principle Enforces document ownership for all operations on user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secure shipment documents.
     * @path /shipments/{shipmentId}
     * @allow (create) User with UID 'user123' can create a shipment with customerId 'user123'.
     * @allow (get) User with UID 'user123' can read a shipment with customerId 'user123'.
     * @allow (update) User with UID 'user123' can update a shipment with customerId 'user123'.
     * @allow (delete) User with UID 'user123' can delete a shipment with customerId 'user123'.
     * @deny (create) User with UID 'user456' cannot create a shipment with customerId 'user123'.
     * @deny (get) User with UID 'user456' cannot read a shipment with customerId 'user123'.
     * @deny (update) User with UID 'user456' cannot update a shipment with customerId 'user123'.
     * @deny (delete) User with UID 'user456' cannot delete a shipment with customerId 'user123'.
     * @principle Enforces document ownership based on the 'customerId' field.
     */
    match /shipments/{shipmentId} {
      allow get: if isSignedIn() && request.auth.uid == resource.data.customerId;
      allow list: if isSignedIn() && request.auth.uid == resource.data.customerId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.customerId;
      allow update: if isSignedIn() && isExistingOwner(resource.data.customerId) && request.resource.data.customerId == resource.data.customerId;
      allow delete: if isSignedIn() && isExistingOwner(resource.data.customerId);
    }

    /**
     * @description Secure pre-alert documents.
     * @path /preAlerts/{preAlertId}
     * @allow (create) User with UID 'user123' can create a preAlert with customerId 'user123'.
     * @allow (get) User with UID 'user123' can read a preAlert with customerId 'user123'.
     * @allow (update) User with UID 'user123' can update a preAlert with customerId 'user123'.
     * @allow (delete) User with UID 'user123' can delete a preAlert with customerId 'user123'.
     * @deny (create) User with UID 'user456' cannot create a preAlert with customerId 'user123'.
     * @deny (get) User with UID 'user456' cannot read a preAlert with customerId 'user123'.
     * @deny (update) User with UID 'user456' cannot update a preAlert with customerId 'user123'.
     * @deny (delete) User with UID 'user456' cannot delete a preAlert with customerId 'user123'.
     * @principle Enforces document ownership based on the 'customerId' field.
     */
    match /preAlerts/{preAlertId} {
      allow get: if isSignedIn() && request.auth.uid == resource.data.customerId;
      allow list: if isSignedIn() && request.auth.uid == resource.data.customerId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.customerId;
      allow update: if isSignedIn() && isExistingOwner(resource.data.customerId) && request.resource.data.customerId == resource.data.customerId;
      allow delete: if isSignedIn() && isExistingOwner(resource.data.customerId);
    }

    /**
     * @description Secure message documents within conversations.
     * @path /conversations/{conversationId}/messages/{messageId}
     * @allow (create) User with UID 'user123' can create a message with customerId 'user123'.
     * @allow (get) User with UID 'user123' can read a message with customerId 'user123'.
     * @allow (update) User with UID 'user123' can update a message with customerId 'user123'.
     * @allow (delete) User with UID 'user123' can delete a message with customerId 'user123'.
     * @deny (create) User with UID 'user456' cannot create a message with customerId 'user123'.
     * @deny (get) User with UID 'user456' cannot read a message with customerId 'user123'.
     * @deny (update) User with UID 'user456' cannot update a message with customerId 'user123'.
     * @deny (delete) User with UID 'user456' cannot delete a message with customerId 'user123'.
     * @principle Enforces document ownership based on the 'customerId' field.
     */
    match /conversations/{conversationId}/messages/{messageId} {
      allow get: if isSignedIn() && request.auth.uid == resource.data.customerId;
      allow list: if isSignedIn() && request.auth.uid == resource.data.customerId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.customerId;
      allow update: if isSignedIn() && isExistingOwner(resource.data.customerId) && request.resource.data.customerId == resource.data.customerId;
      allow delete: if isSignedIn() && isExistingOwner(resource.data.customerId);
    }

    /**
     * @description Secure invoice documents.
     * @path /invoices/{invoiceId}
     * @allow (create) User with UID 'user123' can create an invoice with customerId 'user123'.
     * @allow (get) User with UID 'user123' can read an invoice with customerId 'user123'.
     * @allow (update) User with UID 'user123' can update an invoice with customerId 'user123'.
     * @allow (delete) User with UID 'user123' can delete an invoice with customerId 'user123'.
     * @deny (create) User with UID 'user456' cannot create an invoice with customerId 'user123'.
     * @deny (get) User with UID 'user456' cannot read an invoice with customerId 'user123'.
     * @deny (update) User with UID 'user456' cannot update an invoice with customerId 'user123'.
     * @deny (delete) User with UID 'user456' cannot delete an invoice with customerId 'user123'.
     * @principle Enforces document ownership based on the 'customerId' field.
     */
    match /invoices/{invoiceId} {
      allow get: if isSignedIn() && request.auth.uid == resource.data.customerId;
      allow list: if isSignedIn() && request.auth.uid == resource.data.customerId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.customerId;
      allow update: if isSignedIn() && isExistingOwner(resource.data.customerId) && request.resource.data.customerId == resource.data.customerId;
      allow delete: if isSignedIn() && isExistingOwner(resource.data.customerId);
    }
  }
}