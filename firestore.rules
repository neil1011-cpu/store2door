rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Admins are defined by existence of a document in the admin_roles collection
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Global Admin Bypass ---
    // Administrators have full access to all paths.
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // --- Collection Rules ---

    // Public read access to shipments by tracking number (for tracking page)
    match /{path=**}/shipments/{id} {
      allow read: if true;
      allow list: if isAdmin();
    }

    match /users/{userId} {
       allow read: if isOwner(userId) || isAdmin();
       allow write: if isOwner(userId) || isAdmin();
       
       match /{allSubcollections=**} {
         allow read, write: if isOwner(userId) || isAdmin();
       }
    }

    // Allow authenticated users to initialize their own admin role
    // This is required for the recovery tool to function.
    match /admin_roles/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    match /invoices/{id} {
        allow read: if isSignedIn() && (isAdmin() || resource.data.customerId == request.auth.uid);
    }
    
    match /{path=**}/pre_alerts/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.customerId == request.auth.uid);
      allow list: if isAdmin();
    }
    
    // Explicit list permissions for collection group queries
    match /{path=**}/pre_alerts {
       allow list: if isAdmin();
    }
    
    match /{path=**}/shipments {
       allow list: if isAdmin();
    }

    // Metadata access for mailbox sequence
    match /metadata/{id} {
      allow read, write: if isSignedIn();
    }
  }
}