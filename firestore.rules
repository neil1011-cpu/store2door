rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /user_profiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /users/{userId} {
       allow read: if isOwner(userId) || isAdmin();
       allow write: if isOwner(userId) || isAdmin();
       
       match /pre_alerts/{id} {
         allow read: if isOwner(userId) || isAdmin();
         allow write: if isOwner(userId) || isAdmin();
       }
       
       match /shipments/{id} {
         allow read: if isOwner(userId) || isAdmin();
         allow write: if isOwner(userId) || isAdmin();
       }
    }

    match /admin_roles/{uid} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or special scripts
    }

    match /invoices/{id} {
        allow read: if isSignedIn() && (isAdmin() || resource.data.customerId == request.auth.uid);
        allow write: if isAdmin();
    }
    
    match /transactions/{id} {
        allow read, write: if isAdmin();
    }
    
    match /sent_emails/{id} {
        allow read, write: if isAdmin();
    }

    match /metadata/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Collection Group Rules ---
    // Required for the Admin Dashboard and Notifications activity feed

    match /{path=**}/pre_alerts/{preAlertId} {
      allow list: if isAdmin();
      allow get: if isSignedIn();
    }

    match /{path=**}/shipments/{shipmentId} {
      allow list: if isAdmin();
      allow get: if isSignedIn();
    }
  }
}