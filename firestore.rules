rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Admins are defined by existence of a document in the admin_roles collection
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Global Admin Bypass ---
    // This allows administrators full access to the database, ensuring admin panels work perfectly.
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // --- Collection Rules ---

    match /users/{userId} {
       allow read: if isOwner(userId) || isAdmin();
       allow write: if isOwner(userId) || isAdmin();
       
       match /{allSubcollections=**} {
         allow read, write: if isOwner(userId) || isAdmin();
       }
    }

    // Allow authenticated users to read and initialize their own admin role
    // This is CRITICAL for the recovery tool and AuthGuard to work.
    match /admin_roles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    match /invoices/{id} {
        allow read: if isSignedIn() && (isAdmin() || resource.data.customerId == request.auth.uid);
    }
    
    // Tracking page needs public read access to specific shipments by tracking number
    match /{path=**}/shipments/{id} {
      allow read: if true;
    }

    match /{path=**}/pre_alerts/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.customerId == request.auth.uid);
    }
  }
}