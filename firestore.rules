/**
 * @fileoverview Firestore Security Rules for SwiftRoute.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and related data,
 * and allows public read access for certain collections while restricting write access to owners.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.  Strictly controlled by user ownership.
 * - /shipments/{shipmentId}: Stores shipment information.  Write access restricted to the owner (customerId). Read access is public.
 * - /preAlerts/{preAlertId}: Stores pre-alert requests. Write access restricted to the owner (customerId). Read access is public.
 * - /conversations/{conversationId}/messages/{messageId}: Stores messages for support conversations. Write access restricted to the owner (customerId). Read access is public.
 * - /invoices/{invoiceId}: Stores invoice information. Write access restricted to the owner (customerId). Read access is public.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data under /users/{userId}.
 * - Listing of users is disallowed.
 * - Write access to shipments, pre-alerts, conversations, and invoices are restricted to the owner (customerId).
 * - Public read access is allowed for shipments, pre-alerts, conversations, and invoices. This is acceptable for prototyping, but MUST be reviewed before production.
 *
 * Denormalization for Authorization:
 * - Shipments, PreAlerts, Messages, and Invoices include a `customerId` field to simplify owner-based security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (create) User with matching id can create their profile.
     * @allow (get, update, delete) User with matching id can access their profile.
     * @deny (create, get, update, delete) User with non-matching id cannot access this profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to shipments, but restricts write access to the owner.
     * @path /shipments/{shipmentId}
     * @allow (get, list) Any user can read shipment data.
     * @allow (create) User with matching customerId can create a shipment.
     * @allow (update, delete) User with matching customerId can update or delete a shipment.
     * @deny (create, update, delete) User with non-matching customerId cannot write shipment data.
     * @principle Allows public read access with owner-only writes.
     */
    match /shipments/{shipmentId} {
      function isOwner(customerId) {
        return request.auth.uid == customerId;
      }

      function isExistingOwner(customerId) {
        return isOwner(customerId) && resource != null;
      }

      allow get, list: if true;
      allow create: if isOwner(request.resource.data.customerId);
      allow update: if isExistingOwner(resource.data.customerId);
      allow delete: if isExistingOwner(resource.data.customerId);
    }

    /**
     * @description Allows public read access to pre-alerts, but restricts write access to the owner.
     * @path /preAlerts/{preAlertId}
     * @allow (get, list) Any user can read pre-alert data.
     * @allow (create) User with matching customerId can create a pre-alert.
     * @allow (update, delete) User with matching customerId can update or delete a pre-alert.
     * @deny (create, update, delete) User with non-matching customerId cannot write pre-alert data.
     * @principle Allows public read access with owner-only writes.
     */
    match /preAlerts/{preAlertId} {
      function isOwner(customerId) {
        return request.auth.uid == customerId;
      }

      function isExistingOwner(customerId) {
        return isOwner(customerId) && resource != null;
      }

      allow get, list: if true;
      allow create: if isOwner(request.resource.data.customerId);
      allow update: if isExistingOwner(resource.data.customerId);
      allow delete: if isExistingOwner(resource.data.customerId);
    }

    /**
     * @description Allows users to read and write messages within a conversation, restricting access to the owner.
     * @path /conversations/{conversationId}/messages/{messageId}
     * @allow (get, list) Any user can read messages.
     * @allow (create) User with matching customerId can create a message.
     * @allow (update, delete) User with matching customerId can update or delete a message.
     * @deny (create, update, delete) User with non-matching customerId cannot write message data.
     * @principle Enforces document ownership for writes, allows public reads.
     */
    match /conversations/{conversationId}/messages/{messageId} {
      function isOwner(customerId) {
        return request.auth.uid == customerId;
      }

      function isExistingOwner(customerId) {
        return isOwner(customerId) && resource != null;
      }

      allow get, list: if true;
      allow create: if isOwner(request.resource.data.customerId);
      allow update: if isExistingOwner(resource.data.customerId);
      allow delete: if isExistingOwner(resource.data.customerId);
    }

    /**
     * @description Allows public read access to invoices, but restricts write access to the owner.
     * @path /invoices/{invoiceId}
     * @allow (get, list) Any user can read invoice data.
     * @allow (create) User with matching customerId can create an invoice.
     * @allow (update, delete) User with matching customerId can update or delete an invoice.
     * @deny (create, update, delete) User with non-matching customerId cannot write invoice data.
     * @principle Allows public read access with owner-only writes.
     */
    match /invoices/{invoiceId} {
      function isOwner(customerId) {
        return request.auth.uid == customerId;
      }

      function isExistingOwner(customerId) {
        return isOwner(customerId) && resource != null;
      }

      allow get, list: if true;
      allow create: if isOwner(request.resource.data.customerId);
      allow update: if isExistingOwner(resource.data.customerId);
      allow delete: if isExistingOwner(resource.data.customerId);
    }
  }
}