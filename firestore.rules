rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isNewUser(userId) {
      return isOwner(userId)
             && !exists(/databases/$(database)/documents/users/$(userId));
    }

    function isUpdatingOwnProfile(userId) {
      return isOwner(userId)
             && resource.data.id == userId;
    }

    // First admin logic using a sentinel document
    function noAdminInitialized() {
      return !exists(/databases/$(database)/documents/system/admin_initialized);
    }

    function isCreatingFirstAdmin(userId) {
      return isOwner(userId) && noAdminInitialized();
    }


    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      allow create: if
        (
          isNewUser(userId)
          && request.resource.data.id == userId
        )
        || isCreatingFirstAdmin(userId);

      allow update: if isUpdatingOwnProfile(userId) || isAdmin();
      allow delete: if isAdmin();
    }


    // --- USER SUBCOLLECTIONS ---
    match /users/{userId}/{subcollection}/{docId} {
      allow get, list: if isOwner(userId) || isAdmin();

      allow create: if
        (isOwner(userId) || isAdmin())
        && request.resource.data.customerId == userId;

      allow update: if
        (isOwner(userId) || isAdmin())
        && request.resource.data.customerId == resource.data.customerId;

      allow delete: if isOwner(userId) || isAdmin();
    }


    // --- COLLECTION GROUPS FOR ADMINS ---
    match /{path=**}/shipments/{shipmentId} {
      allow get, list: if isAdmin();
    }

    match /{path=**}/pre_alerts/{preAlertId} {
      allow get, list: if isAdmin();
    }

    match /{path=**}/conversations/{convoId} {
      allow get, list: if isAdmin();
    }


    // --- ADMIN-ONLY GLOBAL DATA ---
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
    }

    match /flight_manifests/{manifestId} {
      allow read, write: if isAdmin();
    }

    match /profit_loss_statements/{id} {
      allow read, write: if isAdmin();
    }

    match /rates/{rateId} {
      allow read, write: if isAdmin();
    }


    // --- ADMIN ROLES ---
    match /roles_admin/{userId} {
      allow get: if request.auth != null && isOwner(userId);

      // First admin creation only
      allow create: if isCreatingFirstAdmin(userId);

      allow update, delete: if false;
    }


    // --- SYSTEM SENTINEL FOR FIRST ADMIN ---
    match /system/admin_initialized {
      // Only admin can create this after first admin setup
      allow write: if isAdmin();
      allow read: if isAdmin();
    }

  }
}
