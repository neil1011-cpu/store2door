rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Admins are defined by existence of a document in the admin_roles collection
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Global Admin Bypass ---
    // Administrators have full access to all paths, including collection groups.
    match /{allPaths=**} {
      allow read, write, list: if isAdmin();
    }

    // --- Collection Rules ---

    // Public read access to shipments by tracking number (for tracking page)
    match /{path=**}/shipments/{id} {
      allow read: if true;
      allow list: if isAdmin();
    }

    // Users and their subcollections
    match /users/{userId} {
       allow read: if isOwner(userId) || isAdmin();
       allow write: if isOwner(userId) || isAdmin();
       
       match /{allSubcollections=**} {
         allow read, write, list: if isOwner(userId) || isAdmin();
       }
    }

    // Allow authenticated users to initialize their own admin role
    // This is required for the recovery tool and first-time setup to function.
    match /admin_roles/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
    }
    
    // Invoices access
    match /invoices/{id} {
        allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.customerId == request.auth.uid));
        allow list: if isAdmin();
    }
    
    // Explicit matches for Collection Groups (fixing the 'list' error at root)
    match /{path=**}/pre_alerts/{id} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.customerId == request.auth.uid));
      allow list: if isAdmin();
    }
    
    match /{path=**}/pre_alerts {
       allow list: if isAdmin();
    }
    
    match /{path=**}/shipments {
       allow list: if isAdmin();
    }

    // Transactions and Financials
    match /transactions/{id} {
       allow read, list, write: if isAdmin();
    }

    // Metadata access for mailbox sequence
    match /metadata/{id} {
      allow read, write: if isSignedIn();
    }
    
    // Sent emails history
    match /sent_emails/{id} {
       allow read, list: if isAdmin();
    }
  }
}