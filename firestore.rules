
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Administrators have full access.
    // Reverted email fallback to admin@neilussolutions.com
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email == "admin@neilussolutions.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Global Administrative Override ---
    match /{allPaths=**} {
      allow read, write, list: if isAdmin();
    }

    // --- Public & User Collection Rules ---

    match /users/{userId} {
       allow read, write: if isOwner(userId) || isAdmin();
       
       match /{allSubcollections=**} {
         allow read, write, list: if isOwner(userId) || isAdmin();
       }
    }

    match /users {
      allow list: if isAdmin();
    }
    
    match /{path=**}/pre_alerts/{id} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
    }
    
    match /{path=**}/shipments/{id} {
       allow read: if true;
       allow list: if isAdmin();
    }

    match /transactions/{id} {
       allow read, write, list: if isAdmin();
    }
    
    match /invoices/{id} {
       allow read, write, list: if isAdmin();
    }

    match /admin_roles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == "admin@neilussolutions.com");
    }

    match /metadata/{id} {
      allow read, write: if isAdmin() || isSignedIn();
    }

    match /system_logs/{id} {
       allow read, write: if isAdmin();
    }
  }
}
