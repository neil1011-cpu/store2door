rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isNewUser(userId) {
      return isOwner(userId)
             && !exists(/databases/$(database)/documents/users/$(userId));
    }

    function isUpdatingOwnProfile(userId) {
      return isOwner(userId)
             && resource.data.id == userId;
    }

    // First admin logic using a sentinel document
    function noAdminInitialized() {
      // This function now checks if the collection is empty by trying to get the first doc.
      // This is more reliable than exists() on a collection path.
      return get(/databases/$(database)/documents/roles_admin).size() == 0;
    }

    function isCreatingFirstAdmin(userId) {
      // Ensures the user is logged in and no other admins exist.
      return isOwner(userId) && size(get(/databases/$(database)/documents/roles_admin).data) == 0;
    }


    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      allow create: if
        (
          isNewUser(userId)
          && request.resource.data.id == userId
        )
        || (isAdmin() && request.resource.data.id == userId) // Allow admin to create user doc
        || (isOwner(userId) && !exists(/databases/$(database)/documents/users/$(userId))); // Simplified rule for user creating their own doc

      allow update: if isUpdatingOwnProfile(userId) || isAdmin();
      allow delete: if isAdmin();
    }


    // --- USER SUBCOLLECTIONS ---
    match /users/{userId}/{subcollection}/{docId} {
      allow get, list: if isOwner(userId) || isAdmin();

      allow create: if
        (isOwner(userId) || isAdmin())
        && request.resource.data.customerId == userId;

      allow update: if
        (isOwner(userId) || isAdmin())
        && request.resource.data.customerId == resource.data.customerId;

      allow delete: if isOwner(userId) || isAdmin();
    }


    // --- COLLECTION GROUPS FOR ADMINS ---
    match /{path=**}/shipments/{shipmentId} {
      allow get, list: if isAdmin();
    }

    match /{path=**}/pre_alerts/{preAlertId} {
      allow get, list: if isAdmin();
    }

    match /{path=**}/conversations/{convoId} {
      allow get, list: if isAdmin();
    }


    // --- ADMIN-ONLY GLOBAL DATA ---
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
    }

    match /flight_manifests/{manifestId} {
      allow read, write: if isAdmin();
    }

    match /profit_loss_statements/{id} {
      allow read, write: if isAdmin();
    }

    match /rates/{rateId} {
      allow read, write: if isAdmin();
    }


    // --- ADMIN ROLES ---
    match /roles_admin/{userId} {
      // Allow a user to check if they have an admin role doc. Admins can check anyone.
      allow get: if isOwner(userId) || isAdmin();
      
      // Allow a LIST operation only if the query is just checking for existence.
      // This is crucial for the /setup-admin page to work without being logged in.
      allow list: if request.query.limit == 1;

      // Allow a user to create their own admin role document ONLY IF they are the first user.
      // The `isCreatingFirstAdmin` function is no longer needed here because we can check size directly.
      allow create: if request.auth != null && size(get(/databases/$(database)/documents/roles_admin).data) == 0;

      allow update, delete: if false; // Disallow updating or deleting roles for safety.
    }


    // --- SYSTEM SENTINEL FOR FIRST ADMIN ---
    // This is no longer the primary mechanism, but can be kept for other system flags.
    match /system/{docId} {
      allow read, write: if isAdmin();
    }

  }
}