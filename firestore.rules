rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /user_profiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /users/{userId} {
       allow read: if isOwner(userId) || isAdmin();
       allow write: if isOwner(userId) || isAdmin();
       
       match /{allSubcollections=**} {
         allow read, write: if isOwner(userId) || isAdmin();
       }
    }

    // Admin List Users for Dashboard
    match /users {
      allow list: if isAdmin();
    }

    match /admin_roles/{uid} {
      // Authenticated users can check for privileges, and admins can check any record
      allow read: if isSignedIn();
      // Allow users to initialize their own administrative record (existence signifies privilege)
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    match /admin_roles {
      allow list: if isAdmin();
    }

    match /invoices/{id} {
        allow read: if isSignedIn() && (isAdmin() || resource.data.customerId == request.auth.uid);
        allow write: if isAdmin();
        allow list: if isAdmin();
    }
    
    match /transactions/{id} {
        allow read, write, list: if isAdmin();
    }
    
    match /sent_emails/{id} {
        allow read, write, list: if isAdmin();
    }

    match /metadata/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /flight_manifests/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Collection Group Rules for Admin Dashboards ---
    match /{path=**}/pre_alerts/{preAlertId} {
      allow list: if isAdmin();
      allow read: if isSignedIn() && (isAdmin() || resource.data.customerId == request.auth.uid);
    }

    match /{path=**}/shipments/{shipmentId} {
      allow list: if isAdmin();
      allow read: if isSignedIn() && (isAdmin() || resource.data.customerId == request.auth.uid);
    }
  }
}
