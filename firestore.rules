rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Administrators have full access.
    // Explicit email fallback ensures primary admin can recover the system.
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email == "admin@neilussolutions.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Global Administrative Override ---
    // Grants full unrestricted access to any path for recognized admins.
    match /{allPaths=**} {
      allow read, write, list: if isAdmin();
    }

    // --- Public & User Collection Rules ---

    // Allow public tracking by specific ID
    match /users/{userId}/shipments/{id} {
      allow read: if true;
    }

    // Secure access to profile roles
    match /admin_roles/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // User-specific data access
    match /users/{userId} {
       allow read, write: if isOwner(userId) || isAdmin();
       
       match /{allSubcollections=**} {
         allow read, write, list: if isOwner(userId) || isAdmin();
       }
    }
    
    // Explicit authorization for global Collection Group queries
    match /{path=**}/pre_alerts/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.customerId == request.auth.uid);
      allow list: if isAdmin();
    }
    
    match /{path=**}/shipments/{id} {
       allow list: if isAdmin();
    }

    // Financial Records
    match /transactions/{id} {
       allow read, write, list: if isAdmin();
    }
    
    match /invoices/{id} {
       allow read, write, list: if isAdmin();
    }

    // System Metadata
    match /metadata/{id} {
      allow read, write: if isSignedIn();
    }
  }
}
